{
    "apiVersion": 3,
    "name": "spectra-child/project-grid",
    "title": "Project Grid",
    "description": "Filterable grid of video projects with taxonomy filters.",
    "category": "media",
    "icon": "grid-view",
    "keywords": ["project", "video", "portfolio", "grid", "filter"],
    "supports": {
        "html": false,
        "align": ["wide", "full"]
    },
    "attributes": {
        "postsPerPage": {
            "type": "number",
            "default": 6
        },
        "showLoadMore": {
            "type": "boolean",
            "default": true
        },
        "preSelectedIndustry": {
            "type": "string",
            "default": ""
        },
        "preSelectedService": {
            "type": "string",
            "default": ""
        },
        "showFeaturedOnly": {
            "type": "boolean",
            "default": false
        },
        "showFilterBar": {
            "type": "boolean",
            "default": true
        },
        "columns": {
            "type": "number",
            "default": 3
        },
        "orderBy": {
            "type": "string",
            "default": "date"
        },
        "showServiceRow": {
            "type": "boolean",
            "default": true
        }
    },
    "editorScript": "file:./editor.js",
    "render": "file:./render.php"
}
